<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<StackPane prefHeight="292.0" prefWidth="500.0" style="-fx-background-color: #F5F5F5; -fx-background-radius: 15;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.artikelfinder.MainController">


    <!-- Your UI on top -->
      <VBox alignment="CENTER" spacing="12">


                <HBox alignment="CENTER" spacing="5">

              <Button fx:id="saveButton" maxWidth="195" onAction="#save" prefHeight="60" prefWidth="195" style="-fx-background-color: #4F46E5;                            -fx-text-fill: black;                            -fx-font-size: 16 px;                            -fx-background-radius: 8;" text="add And Save Word" />
                    <TextField fx:id="toAddNoun" maxWidth="195" prefHeight="60" prefWidth="195" promptText="write your new word " />
              <ComboBox fx:id="ArtikelSwitcher" maxHeight="60" maxWidth="95" prefWidth="95" promptText="Chose Artikel" />


              </HBox>

              <TextField fx:id="nounInput" maxWidth="500" prefHeight="60" prefWidth="500" promptText="Enter German noun" style="-fx-text-fill: black; -fx-font-size: 16 px" />

              <Button fx:id="findartikel" maxWidth="500" onAction="#handleCheck" prefHeight="60" prefWidth="500" style="-fx-background-color: #4F46E5;                            -fx-text-fill: black;                            -fx-font-size: 16 px;                            -fx-background-radius: 8;" text="Find Artikel" />

              <Label fx:id="resultLabel" maxWidth="500" prefHeight="25" prefWidth="500" style="-fx-text-fill: black; -fx-font-size: 16 px; -fx-alignment: center;" text="it will be here" />



       </VBox>

</StackPane>
