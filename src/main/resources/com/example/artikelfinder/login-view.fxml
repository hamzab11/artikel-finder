<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefWidth="1440"
            prefHeight="900"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.example.artikelfinder.LoginControler"
            style="-fx-background-color: #F5F5F5;">

    <!-- LOGO -->
    <Label text="Artikel Finder"
           layoutX="15"
           layoutY="15"
           style="-fx-font-size: 16px;
                  -fx-font-weight: bold;
                  -fx-text-fill: #111827;"/>


    <!-- DATE TIME -->
    <HBox alignment="CENTER_RIGHT"
          spacing="6"
          AnchorPane.topAnchor="20"
          AnchorPane.rightAnchor="45">

        <!-- Date -->
        <Label text="Date:"
               style="-fx-font-size: 13px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #6B7280;"/>

        <Label fx:id="dateValueLabel"
               text="03.05.2026"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #111827;"/>

        <!-- Time -->
        <Label text="Time:"
               style="-fx-font-size: 13px;
                      -fx-font-weight: bold;
                      -fx-text-fill: #6B7280;"/>

        <Label fx:id="timeValueLabel"
               text="18:42:10"
               style="-fx-font-size: 13px;
                      -fx-text-fill: #111827;"/>

    </HBox>


    <!-- MAIN CONTENT -->
    <HBox alignment="CENTER"
          spacing="180"
          AnchorPane.topAnchor="140"
          AnchorPane.leftAnchor="300">

        <!-- LEFT SIDE -->
        <VBox fx:id="loginForm"
                spacing="35"
              alignment="CENTER_LEFT"
               >

            <!-- TEXT -->
            <VBox spacing="12">

                <Label text="Sign in to"
                       style="-fx-font-size: 42px;
                              -fx-font-weight: bold;
                              -fx-text-fill: #111827;"/>

                <Label text="Der Artikel Wird Einfach"
                       style="-fx-font-size: 28px;
                              -fx-text-fill: #1F2937;"/>

                <Label text="By Hamcik"
                       style="-fx-font-size: 13px;
                              -fx-text-fill: #4F46E5;"/>

            </VBox>

            <!-- IMAGE -->
            <ImageView fitWidth="313"
                       fitHeight="556"
                       preserveRatio="true">

                <image>
                    <Image url="@../../../images/person.png"/>
                </image>

            </ImageView>

        </VBox>


        <!-- RIGHT SIDE -->
        <VBox spacing="25"
              alignment="CENTER_LEFT"
              translateY="-60">

            <!-- TITLE -->
            <Label text="Sign in"
                   style="-fx-font-size: 28px;
                          -fx-text-fill: #111827;"/>

            <!-- USERNAME -->
            <TextField fx:id="usernameField"
                       promptText="Enter email or user name"
                       prefWidth="330"
                       prefHeight="55"
                       style="-fx-font-size: 15px;
                              -fx-background-color: white;
                              -fx-background-radius: 8;
                              -fx-border-radius: 8;
                              -fx-border-color: #D1D5DB;
                              -fx-padding: 0 0 0 12;"/>

            <!-- PASSWORD -->
            <PasswordField fx:id="passwordField"
                           promptText="Password"
                           prefWidth="330"
                           prefHeight="55"
                           style="-fx-font-size: 15px;
                                  -fx-background-color: white;
                                  -fx-background-radius: 8;
                                  -fx-border-radius: 8;
                                  -fx-border-color: #D1D5DB;
                                  -fx-padding: 0 0 0 12;"/>

            <!-- LOGIN BUTTON -->
            <Button fx:id="loginButton"
                    onAction="#handleLogin"
                    text="Login"
                    prefWidth="330"
                    prefHeight="60"
                    style="-fx-background-color: #4F46E5;
                           -fx-text-fill: white;
                           -fx-font-size: 15px;
                           -fx-font-weight: bold;
                           -fx-background-radius: 8;"/>

            <!-- ERROR MESSAGE -->
            <Label fx:id="fieldLog"
                   text=""
                   prefWidth="330"
                   alignment="CENTER"
                   style="-fx-text-fill: red;
                          -fx-font-size: 14px;"/>

        </VBox>

    </HBox>

</AnchorPane>