<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<AnchorPane prefHeight="900" prefWidth="1440" style="-fx-background-color: #F5F5F5;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.artikelfinder.LoginController">

    <!-- LOGO -->
    <Label layoutX="15" layoutY="15" style="-fx-font-size: 16px;                   -fx-font-weight: bold;                   -fx-text-fill: #111827;" text="Artikel Finder" />


    <!-- DATE TIME -->
    <HBox alignment="CENTER_RIGHT" spacing="6" AnchorPane.rightAnchor="45" AnchorPane.topAnchor="20">

        <!-- Date -->
        <Label style="-fx-font-size: 13px;                       -fx-font-weight: bold;                       -fx-text-fill: #6B7280;" text="Date:" />

        <Label fx:id="dateValueLabel" style="-fx-font-size: 13px;                       -fx-text-fill: #111827;" text="03.05.2026" />

        <!-- Time -->
        <Label style="-fx-font-size: 13px;                       -fx-font-weight: bold;                       -fx-text-fill: #6B7280;" text="Time:" />

        <Label fx:id="timeValueLabel" style="-fx-font-size: 13px;                       -fx-text-fill: #111827;" text="18:42:10" />

    </HBox>


    <!-- MAIN CONTENT -->
    <HBox alignment="CENTER" spacing="180" AnchorPane.leftAnchor="300" AnchorPane.topAnchor="140">

        <!-- LEFT SIDE -->
        <VBox fx:id="loginForm" alignment="CENTER_LEFT" spacing="35">

            <!-- TEXT -->
            <VBox spacing="12">

                <Label style="-fx-font-size: 42px;                               -fx-font-weight: bold;                               -fx-text-fill: #111827;" text="Sign in to" />

                <Label style="-fx-font-size: 28px;                               -fx-text-fill: #1F2937;" text="Der Artikel Wird Einfach" />

                <Label style="-fx-font-size: 13px;                               -fx-text-fill: #4F46E5;" text="By Hamcik" />

            </VBox>

            <!-- IMAGE -->
            <ImageView fitHeight="556" fitWidth="313" preserveRatio="true">

                <image>
                    <Image url="@../../../images/person.png" />
                </image>

            </ImageView>

        </VBox>


        <!-- RIGHT SIDE -->
        <VBox alignment="CENTER_LEFT" spacing="10" translateY="-60">

            <!-- TITLE -->
            <Label style="-fx-font-size: 28px;                           -fx-text-fill: #111827;" text="Sign in" />

            <!-- USERNAME -->
            <TextField fx:id="usernameField" prefHeight="55" prefWidth="330" promptText="Enter email or user name" style="-fx-font-size: 15px;                               -fx-background-color: white;                               -fx-background-radius: 8;                               -fx-border-radius: 8;                               -fx-border-color: #D1D5DB;                               -fx-padding: 0 0 0 12;" />

            <!-- PASSWORD -->
            <PasswordField fx:id="passwordField" prefHeight="55" prefWidth="330" promptText="Password" style="-fx-font-size: 15px;                                   -fx-background-color: white;                                   -fx-background-radius: 8;                                   -fx-border-radius: 8;                                   -fx-border-color: #D1D5DB;                                   -fx-padding: 0 0 0 12;" />

            <!-- LOGIN BUTTON -->
            <Button fx:id="loginButton" onAction="#handleLogin" prefHeight="60" prefWidth="330" style="-fx-background-color: #4F46E5;                            -fx-text-fill: white;                            -fx-font-size: 15px;                            -fx-font-weight: bold;                            -fx-background-radius: 8;" text="Login" />

            <HBox alignment="CENTER" maxHeight="25" maxWidth="250" prefHeight="25" prefWidth="250.0" spacing="0">
                <children>
                    <Label text="I don't have account ? "
                           alignment="CENTER_RIGHT"
                           prefHeight="25"
                           maxHeight="25"
                           prefWidth="200"
                           maxWidth="200"/>
                    <Hyperlink onAction="#openRegisterWindow"
                               alignment="CENTER_LEFT"
                               text="SignUp"
                               maxHeight="25"
                               maxWidth="50"
                               prefHeight="25"
                               prefWidth="50"
                               style="-fx-text-fill: #4338CA; -fx-underline: true; -fx-cursor: hand;" />
                </children>
            </HBox>

            <!-- ERROR MESSAGE -->
            <Label fx:id="fieldLog" alignment="CENTER" prefWidth="330" style="-fx-text-fill: red;                           -fx-font-size: 14px;" text="" />

        </VBox>

    </HBox>

</AnchorPane>
